rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.email == "629ahmdbsman@gmail.com" ||
          request.auth.token.email == "Basmanaljumayli51@gmail.com"
        );
    }

    function isVisibleReview() {
      return resource.data.isVisible == true;
    }

    function isVisibleGallery() {
      return resource.data.isVisible == true;
    }

    function isAllowedBookingCreate() {
      return request.resource.data.status == 'pending'
        && request.resource.data.customerName is string
        && request.resource.data.phone is string
        && request.resource.data.bookingDate is string
        && request.resource.data.bookingTime is string
        && request.resource.data.serviceName is string
        && request.resource.data.createdAt is string;
    }

    match /bookings/{bookingId} {
      allow create: if isAllowedBookingCreate();
      allow read, update, delete: if isAdmin();
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scheduledClosures/{closureId} {
      allow read, write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if isVisibleReview() || isAdmin();
      allow write: if isAdmin();
    }

    match /gallery/{galleryId} {
      allow read: if isVisibleGallery() || isAdmin();
      allow write: if isAdmin();
    }

    match /bannedUsers/{docId} {
      allow read, write: if isAdmin();
    }

    match /bookingQueueCounters/{docId} {
      allow read, write: if isAdmin();
    }
  }
}